NODE_ENV=local
PORT=30000

# PostgreSQL / TimescaleDB
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=aio


# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# MinIO (S3 Compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=default

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883

# Server Configuration
CORS_ORIGIN=http://localhost:40000

# Better Auth Configuration
# Generate a secret with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=3fafc9cc11f3057635708c8e3da9e733e8e530132c9de2764f1e7d8b0fe64c07BETTER_AUTH_URL=http://localhost:30000
BETTER_AUTH_BASE_PATH=/api/v1/auth

# Frontend URL (used for redirects and email links)
UI_URL=http://localhost:40000

