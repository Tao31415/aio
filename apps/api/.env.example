NODE_ENV=local
PORT=30000

# PostgreSQL / TimescaleDB
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nest_better_auth

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (S3 Compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=default

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883


# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=nest_better_auth

# Server Configuration
PORT=3000
CORS_ORIGIN=http://localhost:3001

# Better Auth Configuration
# Generate a secret with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=your-secret-key-here

# Frontend URL (used for redirects and email links)
UI_URL=http://localhost:3001

# Email Configuration (optional - for production)- NOTE THE MODULE IS NOT IMPLEMENTED
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=noreply@example.com
