{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node", "jest"],
    "strict": false,
    "paths": {
      "@/*": ["./src/*"],
      "@auth/*": ["./src/module/auth/*"],
      "@config/*": ["./src/module/config/*"],
      "@database/*": ["./src/module/database/*"],
      "@log/*": ["./src/module/log/*"],
      "@main/*": ["./src/module/main/*"],
      "@mqtt/*": ["./src/module/mqtt/*"],
      "@redis/*": ["./src/module/redis/*"],
      "@storage/*": ["./src/module/storage/*"],
      "@user/*": ["./src/module/user/*"],
      "@system/*": ["./src/module/system/*"],
      "@guard/*": ["./src/common/guards/*"],
      "@common/*": ["./src/common/*"]
    }
  }
}
