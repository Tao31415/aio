NUXT_PUBLIC_ENV=local
PORT=40000
NUXT_PUBLIC_LOG_LEVEL=debug




# API 基础 URL（默认 /api）
NUXT_PUBLIC_API_BASE=/api

# 是否启用 Mock 数据（开发模式，true/false）
NUXT_PUBLIC_MOCK=true

# -----------------------------------------------------------------------------
# 演示账号配置（仅开发/演示环境使用，生产环境请移除）
# -----------------------------------------------------------------------------

# 演示账号邮箱
NUXT_PUBLIC_DEMO_EMAIL=admin@halolight.h7ml.cn

# 演示账号密码
NUXT_PUBLIC_DEMO_PASSWORD=123456

# 是否显示演示账号提示
NUXT_PUBLIC_SHOW_DEMO_HINT=true

# 是否启用用户注册（默认关闭）
NUXT_PUBLIC_ENABLE_REGISTRATION=false

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------

# 应用标题
NUXT_PUBLIC_APP_TITLE=Admin Pro

# 公司/品牌名称
NUXT_PUBLIC_BRAND_NAME=Halolight

# Google Analytics ID
# NUXT_PUBLIC_GA_ID=
