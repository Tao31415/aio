# API
PORT=3000
API_PORT=3000

# PostgreSQL (主数据库)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=aio

# TimescaleDB (时序数据库)
TS_DB_HOST=timescale
TS_DB_PORT=5433
TS_DB_USER=postgres
TS_DB_PASSWORD=postgres
TS_DB_NAME=timeseries

# MinIO (S3 兼容对象存储)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_DEFAULT_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Eclipse Mosquitto (MQTT Broker)
MOSQUITTO_PORT=1883
MOSQUITTO_WS_PORT=1884
MOSQUITTO_MQTTS_PORT=8883
MOSQUITTO_UID=1000
MOSQUITTO_GID=1000

# Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443

# Dozzle (Docker 日志查看)
DOZZLE_PORT=8080


REDIS_PASSWORD=redis
REDIS_PORT=6379
