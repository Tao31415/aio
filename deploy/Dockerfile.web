# ===== Web Dockerfile =====
# 多阶段构建：deps -> builder -> runtime

# ===== 依赖阶段 (仅 Web) =====
FROM oven/bun:alpine AS deps
WORKDIR /app
ENV BUN_INSTALL_REGISTRY='https://registry.npmmirror.com'
# 只复制 Web 需要的 package.json
COPY package.json bun.lock ./
COPY apps/web/package.json ./apps/web/
COPY packages/utils/package.json ./packages/utils/
RUN bun install --ignore-scripts

# ===== 构建阶段 =====
FROM oven/bun:alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/utils/node_modules ./packages/utils/node_modules
COPY . .
RUN bun run build:utils && bun run build:web

# ===== Web 运行时 =====
FROM oven/bun:alpine AS web
WORKDIR /app
ENV NODE_ENV=production
# 只复制 Web 需要的 node_modules
COPY --from=deps /app/node_modules /app/node_modules
COPY --from=deps /app/apps/web/node_modules /app/apps/web/node_modules
COPY --from=deps /app/packages/utils/node_modules /app/packages/utils/node_modules
COPY --from=deps /app/packages/utils/package.json /app/packages/utils/package.json
# 只复制 Web 的编译产物
COPY --from=builder /app/packages/utils/dist /app/packages/utils/dist
COPY --from=builder /app/apps/web/.output /app/apps/web/.output
COPY --from=builder /app/apps/web/.env.production /app/apps/web/.env
WORKDIR /app/apps/web
EXPOSE 4000
CMD ["bun", ".output/server/index.mjs"]
