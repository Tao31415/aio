{
  "name": "aio",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "vp run -r --parallel dev",
    "dev:utils": "vp run @aio/utils#dev",
    "dev:api": "vp run api#dev",
    "dev:web": "vp run web#dev",
    "dev:api:debug": "vp run api#dev:debug",
    "build": "vp run -r build",
    "build:utils": "vp run @aio/utils#build",
    "build:api": "vp run api#build",
    "build:web": "vp run web#build",
    "test:api": "vp run api#test",
    "preview": "vp run -r preview",
    "preview:web": "vp run web#preview",
    "preview:api": "vp run api#preview",
    "prepare": "vp config",
    "check": "vp check",
    "clean": "vp run -r clean",
    "cleanAll": "vp run -r cleanAll",
    "reinstall": "bun run cleanAll && bun install",
    "kill": "bun run script/kill-ports.sh"
  },
  "dependencies": {
    "better-auth": "^1.6.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "rolldown": "^1.0.0-rc.15",
    "shx": "^0.4.0",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.12",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.16",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.16",
    "vite-plus": "0.1.16"
  }
}
