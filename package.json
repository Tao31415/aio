{
  "name": "aio",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run dev:utils & bun run dev:api & bun run dev:web",
    "dev:utils": "vp run @aio/utils#dev",
    "dev:api": "vp run api#dev",
    "dev:web": "vp run web#dev",
    "dev:api:debug": "vp run api#dev:debug",
    "build": "bun run build:utils && bun run build:api && bun run build:web",
    "build:utils": "vp run @aio/utils#build",
    "build:api": "vp run api#build",
    "build:web": "vp run web#build",
    "test:api": "vp run api#test",
    "preview": "bun run build && bun run preview:web & bun run preview:api",
    "preview:web": "vp run web#preview",
    "preview:api": "vp run api#preview",
    "prepare": "vp config",
    "check": "vp check",
    "cleanAll": "vp run api#clean & vp run web#clean & vp run @aio/utils#clean && rm -rf node_modules",
    "reinstall": "bun run cleanAll && bun install"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260409.1",
    "rolldown": "^1.0.0-rc.15",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.12",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "0.1.16"
  }
}
